# ── Resend (za Render / produkcijo) ──────────────────────────
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxx
# MAIL_FROM=onboarding@resend.dev   # ali tvoja verificirana domena
# DEFAULT_REMINDER_EMAIL=tvoj.email@gmail.com

# ── Gmail SMTP (za lokalno uporabo) ──────────────────────────
GMAIL_USER=tvoj.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=tvoj.email@gmail.com
DEFAULT_REMINDER_EMAIL=tvoj.email@gmail.com

# ── Dostop (za javni Render deployment) ──────────────────────
# APP_ACCESS_CODE=tvoja-tajna-koda
# Ščiti aplikacijo pred javnimi obiskovalci. Hraniti zasebno.
# Zamenjaj, če jo po nesreči deliš.

# ── Skupne nastavitve ─────────────────────────────────────────
PORT=3001
NODE_ENV=production

# SMTP nastavitve (privzeto: Gmail port 465 s TLS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# Alternativa za Render, če port 465 ne deluje:
# SMTP_PORT=587
# SMTP_SECURE=false
